{%- comment -%}
  Horizontal filter bar — desktop-only.

  Renders the same Shopify storefront filters (collection.filters /
  search.filters) as facets.liquid, but as a row of dropdowns that
  open downward on click rather than a vertical sidebar. Used on the
  collection and search pages on screens >=750px. Mobile keeps the
  drawer-style facets.liquid for thumb-friendly full-width controls.

  Layout:
    [ Availability ▾ ]  [ Price ▾ ]  [ Color ▾ ]   [count]   [Sort ▾]

  Each filter is a native <details> + <summary>. The panel opens as
  an absolutely-positioned popover under its summary. JS in
  collection.js wires "click outside to close" and "open one at a
  time" — the markup itself works without JS, just less polished.

  Sort dropdown lives inside this same bar (right-aligned), so the
  toolbar above no longer needs a duplicate sort select. This is
  why callers should NOT render the desktop sort separately when
  this snippet is in use.

  Accepts:
    results          {Object}    required — collection / search drop
    paginate         {Paginate}  optional — total_items count
    show_sort        {Boolean}   optional — render sort select inline
    has_sorting      {Boolean}   optional — only meaningful with show_sort
    enable_filtering {Boolean}   optional — render filter dropdowns
    results_count    {Integer}   optional — count to display in bar
{%- endcomment -%}

{%- liquid
  assign filters = results.filters
  assign sort_by = results.sort_by | default: results.default_sort_by

  assign active_count = 0
  for filter in filters
    assign active_count = active_count | plus: filter.active_values.size
    if filter.type == 'price_range'
      if filter.min_value.value or filter.max_value.value
        assign active_count = active_count | plus: 1
      endif
    endif
  endfor

  assign facet_clear_url = results.url
  if facet_clear_url == blank and results.terms
    assign facet_clear_url = routes.search_url | append: '?q=' | append: results.terms
  endif
-%}

<form class="valor-facets-bar" data-facets data-facets-bar>
  <div class="valor-facets-bar__inner">
    {%- if enable_filtering and filters != empty -%}
      <div class="valor-facets-bar__filters" role="group" aria-label="{{ 'collection.filters.title' | t }}">
        <span class="valor-facets-bar__label">{{ 'collection.filters.filter_by' | t }}</span>

        {%- for filter in filters -%}
          {%- liquid
            assign filter_active = false
            if filter.active_values.size > 0
              assign filter_active = true
            endif
            if filter.type == 'price_range'
              if filter.min_value.value or filter.max_value.value
                assign filter_active = true
              endif
            endif
          -%}
          <details
            class="valor-facets-bar__group{% if filter_active %} valor-facets-bar__group--active{% endif %}"
            data-facets-bar-group
          >
            <summary class="valor-facets-bar__summary">
              <span class="valor-facets-bar__summary-label">
                {{ filter.label }}
                {%- if filter.active_values.size > 0 -%}
                  <span class="valor-facets-bar__summary-count">({{ filter.active_values.size }})</span>
                {%- endif -%}
              </span>
              <svg
                class="valor-facets-bar__summary-icon"
                aria-hidden="true"
                focusable="false"
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>

            <div class="valor-facets-bar__panel" role="group" aria-label="{{ filter.label | escape }}">
              {%- case filter.type -%}
                {%- when 'list' -%}
                  <ul class="valor-facets-bar__values" role="list">
                    {%- for value in filter.values -%}
                      <li class="valor-facets-bar__value">
                        <label class="valor-facets-bar__option">
                          <input
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            class="valor-facets-bar__checkbox"
                            {% if value.active %}
                              checked
                            {% endif %}
                            {% if value.count == 0 and value.active == false %}
                              disabled
                            {% endif %}
                          >
                          <span class="valor-facets-bar__check-box" aria-hidden="true">
                            <svg
                              width="10"
                              height="10"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="3"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                          </span>
                          <span class="valor-facets-bar__option-label">{{ value.label }}</span>
                          {%- if value.count > 0 and value.active == false -%}
                            <span class="valor-facets-bar__option-count">({{ value.count }})</span>
                          {%- endif -%}
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- when 'boolean' -%}
                  <ul class="valor-facets-bar__values" role="list">
                    {%- for value in filter.values -%}
                      <li class="valor-facets-bar__value">
                        <label class="valor-facets-bar__option">
                          <input
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            class="valor-facets-bar__checkbox"
                            {% if value.active %}
                              checked
                            {% endif %}
                          >
                          <span class="valor-facets-bar__check-box" aria-hidden="true">
                            <svg
                              width="10"
                              height="10"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="3"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                          </span>
                          <span class="valor-facets-bar__option-label">{{ value.label }}</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- when 'price_range' -%}
                  <div class="valor-facets-bar__price">
                    <label class="valor-facets-bar__price-field">
                      <span class="valor-facets-bar__price-label">{{ 'collection.filters.from' | t }}</span>
                      <span class="valor-facets-bar__price-input-wrap">
                        <span class="valor-facets-bar__price-currency">{{ cart.currency.symbol }}</span>
                        <input
                          type="text"
                          inputmode="decimal"
                          name="{{ filter.min_value.param_name }}"
                          value="{% if filter.min_value.value %}{{ filter.min_value.value | money_without_currency }}{% endif %}"
                          placeholder="0"
                          data-max="{{ filter.range_max | money_without_currency }}"
                          class="valor-facets-bar__price-input"
                          data-facets-price-min
                        >
                      </span>
                    </label>
                    <label class="valor-facets-bar__price-field">
                      <span class="valor-facets-bar__price-label">{{ 'collection.filters.to' | t }}</span>
                      <span class="valor-facets-bar__price-input-wrap">
                        <span class="valor-facets-bar__price-currency">{{ cart.currency.symbol }}</span>
                        <input
                          type="text"
                          inputmode="decimal"
                          name="{{ filter.max_value.param_name }}"
                          value="{% if filter.max_value.value %}{{ filter.max_value.value | money_without_currency }}{% endif %}"
                          placeholder="{{ filter.range_max | money_without_currency }}"
                          data-max="{{ filter.range_max | money_without_currency }}"
                          class="valor-facets-bar__price-input"
                          data-facets-price-max
                        >
                      </span>
                    </label>
                  </div>
              {%- endcase -%}
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="valor-facets-bar__end">
      {%- if results_count != blank -%}
        <span class="valor-facets-bar__count">
          {%- if results_count == 1 -%}
            {{ 'collection.product_count.one' | t: count: results_count }}
          {%- else -%}
            {{ 'collection.product_count.other' | t: count: results_count }}
          {%- endif -%}
        </span>
      {%- endif -%}

      {%- render 'grid-view-toggle', viewport: 'desktop' -%}

      {%- if show_sort and has_sorting -%}
        <span class="valor-facets-bar__sort-wrap">
          <label class="valor-facets-bar__sort-label">{{ 'collection.sort_by' | t }}</label>
          <select
            class="valor-facets-bar__sort"
            data-collection-sort
            aria-label="{{ 'collection.sort_by' | t }}"
          >
            {%- for option in results.sort_options -%}
              <option
                value="{{ option.value }}"
                {% if option.value == sort_by %}
                  selected
                {% endif %}
              >
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </span>
      {%- endif -%}
    </div>
  </div>

  {%- if active_count > 0 -%}
    <div class="valor-facets-bar__active" role="list">
      {%- for filter in filters -%}
        {%- for value in filter.active_values -%}
          <a class="valor-facets-bar__pill" href="{{ value.url_to_remove }}" role="listitem">
            <span>{{ filter.label }}: {{ value.label }}</span>
            <svg
              aria-hidden="true"
              focusable="false"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </a>
        {%- endfor -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value or filter.max_value.value -%}
            <a class="valor-facets-bar__pill" href="{{ filter.url_to_remove }}" role="listitem">
              <span>
                {{ filter.label }}:
                {%- if filter.min_value.value -%}
                  {{ filter.min_value.value | money }}
                {%- else -%}
                  {{ 0 | money }}
                {%- endif -%}
                –
                {%- if filter.max_value.value -%}
                  {{ filter.max_value.value | money }}
                {%- else -%}
                  {{ filter.range_max | money }}
                {%- endif -%}
              </span>
              <svg
                aria-hidden="true"
                focusable="false"
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      <a class="valor-facets-bar__clear" href="{{ facet_clear_url }}">
        {{ 'collection.filters.clear_all' | t }}
      </a>
    </div>
  {%- endif -%}
</form>
