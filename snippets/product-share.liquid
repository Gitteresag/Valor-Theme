{%- comment -%}
  Renders a share button. JS uses the Web Share API on touch devices and
  falls back to clipboard copy on desktop, with a brief "Link copied"
  message after the fallback succeeds.

  Accepts:
    block   {Block}   required — for settings.share_label and shopify_attributes
{%- endcomment -%}

<div class="valor-mp__share" {{ block.shopify_attributes }} data-share>
  <button
    type="button"
    class="valor-mp__share-btn"
    data-share-button
    aria-label="{{ block.settings.share_label | escape }}"
  >
    <span class="valor-mp__share-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false">
        <circle cx="18" cy="5" r="3"></circle>
        <circle cx="6" cy="12" r="3"></circle>
        <circle cx="18" cy="19" r="3"></circle>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
      </svg>
    </span>
    <span class="valor-mp__share-label">{{ block.settings.share_label | escape }}</span>
  </button>
  <span class="valor-mp__share-message" data-share-message hidden role="status"></span>
</div>
