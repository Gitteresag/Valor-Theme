{% doc %}
Renders the runtime hook for a homepage media section that can activate the transparent header.

@param {string} transparent_header_behavior - Transparent header behavior.
@example
{% render 'transparent-header-trigger', transparent_header_behavior: section.settings.transparent_header_behavior %}
{% enddoc %}

<script>
  (function () {
    var root = document.documentElement;
    var current = document.currentScript;
    var section = current ? current.closest('.shopify-section') : null;
    var main = document.getElementById('MainContent');

    // Only activate the transparent header when this trigger's section is the
    // first section on the page. This mirrors the CSS `:has(:first-child …)`
    // gate (and the valor-sticky-header component) so the script can't strip
    // the header's sticky state / pin it transparent for a media section that
    // isn't actually at the top of the homepage.
    if (!section || !main || main.querySelector(':scope > .shopify-section') !== section) {
      return;
    }

    var header = document.querySelector('.valor-section-header');

    root.classList.add('valor-transparent-header-active');

    if (!header) return;

    header.classList.remove('valor-section-header--sticky', 'valor-section-header--transparent-solid');

    {% if transparent_header_behavior == 'none' %}
      header.classList.remove('valor-section-header--transparent-pinned', 'valor-section-header--animate');
      root.classList.add('valor-transparent-header-ready');
    {% else %}
      header.classList.add('valor-section-header--transparent-pinned');
      requestAnimationFrame(function () {
        header.classList.add('valor-section-header--animate');
        root.classList.add('valor-transparent-header-ready');
      });
    {% endif %}
  })();
</script>
