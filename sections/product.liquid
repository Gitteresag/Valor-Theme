{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="valor-product-images">
  {% for image in product.images %}
    {% render 'image', class: 'valor-product-image', image: image %}
  {% endfor %}
</div>

<div class="valor-product-info">
  <h1>{{ product.title }}</h1>
  <p class="valor-product-info__price">{{ product.price | money }}</p>
  <div class="valor-product-info__description">{{ product.description }}</div>
</div>

<div class="valor-product-form">
  {% form 'product', product %}
    {% assign current_variant = product.selected_or_first_available_variant %}

    <select name="id" class="valor-product-form__variants">
      {% for variant in product.variants %}
        <option
          value="{{ variant.id }}"
          {% if variant == current_variant %}
            selected="selected"
          {% endif %}
        >
          {{ variant.title }} - {{ variant.price | money }}
        </option>
      {% endfor %}
    </select>

    <input type="text" name="quantity" min="1" value="1" class="valor-product-form__quantity">

    <div class="valor-product-form__buttons">
      <input type="submit" value="{{ 'product.add_to_cart' | t }}" class="valor-product-form__submit">
      {{ form | payment_button }}
    </div>
  {% endform %}
</div>

{% stylesheet %}
  /* Horizontally scrollable image carousel on mobile */
  .valor-product-images {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .valor-product-images::-webkit-scrollbar {
    display: none;
  }
  .valor-product-images > * {
    flex: 0 0 100%;
    scroll-snap-align: start;
  }

  /* Product info: spacing between title, price, description */
  .valor-product-info {
    margin-top: 1.5rem;
  }
  .valor-product-info > * + * {
    margin-top: 1rem;
  }

  /* Product form: spacing between variants, quantity, buttons */
  .valor-product-form {
    margin-top: 1.5rem;
  }
  .valor-product-form form > * + * {
    margin-top: 1rem;
  }
  .valor-product-form__variants,
  .valor-product-form__quantity {
    width: 100%;
  }

  /* Add to cart + payment button centered, full width */
  .valor-product-form__buttons {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.75rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
