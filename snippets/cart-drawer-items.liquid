{%- comment -%}
  Renders the cart drawer item list. Used both in initial render and during
  AJAX updates (re-fetched via section_id and re-injected into the drawer).

  Wrapped in <valor-cart-items> so JS can attach quantity-change handlers.
{%- endcomment -%}

<valor-cart-items class="valor-cart-items">
  <ul class="valor-cart-items__list" role="list">
    {%- for item in cart.items -%}
      <li class="valor-cart-items__item" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
        <a href="{{ item.url }}" class="valor-cart-items__image" data-cart-drawer-close>
          {%- if item.image -%}
            {%- assign cart_drawer_image_alt = item.image.alt
              | default: item.product.title
              | default: item.title
              | escape
            -%}
            {{
              item.image
              | image_url: width: 200
              | image_tag: width: 100, height: 100, loading: 'lazy', alt: cart_drawer_image_alt
            }}
          {%- endif -%}
        </a>

        <div class="valor-cart-items__details">
          <div class="valor-cart-items__row">
            <a href="{{ item.url }}" class="valor-cart-items__title" data-cart-drawer-close>
              {{- item.product.title | escape -}}
            </a>
            <div class="valor-cart-items__price-block">
              <span class="valor-cart-items__price">{{ item.final_line_price | money }}</span>
              {%- render 'product-unit-price', line_item: item, class_name: 'valor-cart-items__unit-price' -%}
            </div>
          </div>

          {%- if item.product.has_only_default_variant == false
            or item.properties.size > 0
            or item.selling_plan_allocation
          -%}
            <div class="valor-cart-items__variant">
              {%- if item.product.has_only_default_variant == false -%}
                <span>{{ item.variant.title }}</span>
              {%- endif -%}
              {%- if item.selling_plan_allocation -%}
                <span>{{ item.selling_plan_allocation.selling_plan.name }}</span>
              {%- endif -%}
              {%- for property in item.properties -%}
                {%- assign first_char = property.first | slice: 0 -%}
                {%- if property.last != blank and first_char != '_' -%}
                  <span>
                    {{ property.first | escape }}:
                    {%- if property.last contains '/uploads/' -%}
                      <a href="{{ property.last }}" target="_blank" rel="noopener noreferrer">
                        {{- property.last | split: '/' | last | escape -}}
                      </a>
                    {%- else -%}
                      {{ property.last | escape }}
                    {%- endif -%}
                  </span>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if item.line_level_discount_allocations.size > 0 -%}
            <ul class="valor-cart-items__discounts" aria-label="{{ 'cart.discounts' | t }}">
              {%- for discount in item.line_level_discount_allocations -%}
                <li class="valor-cart-items__discount">
                  <span class="valor-cart-items__discount-icon" aria-hidden="true">−</span>
                  <span class="valor-cart-items__discount-title">
                    {{- discount.discount_application.title | escape -}}
                  </span>
                  <span class="valor-cart-items__discount-amount">(−{{ discount.amount | money }})</span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- if item.original_line_price != item.final_line_price -%}
            <div class="valor-cart-items__compare-price">
              <s>{{ item.original_line_price | money }}</s>
            </div>
          {%- endif -%}

          <div class="valor-cart-items__quantity">
            <div class="valor-cart-items__qty-control">
              <button
                type="button"
                class="valor-cart-items__qty-btn"
                aria-label="{{ 'cart.quantity_decrease' | t }}"
                data-qty-change
                data-line="{{ forloop.index }}"
                data-direction="-1"
              >
                −
              </button>
              <input
                class="valor-cart-items__qty-input"
                type="number"
                name="updates[{{ item.key }}]"
                value="{{ item.quantity }}"
                min="0"
                step="{{ item.variant.quantity_rule.increment }}"
                aria-label="{{ 'cart.quantity_label' | t }}"
                data-qty-input
                data-line="{{ forloop.index }}"
                data-min="{{ item.variant.quantity_rule.min }}"
                data-step="{{ item.variant.quantity_rule.increment }}"
                {% if item.variant.quantity_rule.max != blank %}data-max="{{ item.variant.quantity_rule.max }}"{% endif %}
              >
              <button
                type="button"
                class="valor-cart-items__qty-btn"
                aria-label="{{ 'cart.quantity_increase' | t }}"
                data-qty-change
                data-line="{{ forloop.index }}"
                data-direction="1"
              >
                +
              </button>
            </div>

            <button
              type="button"
              class="valor-cart-items__remove"
              aria-label="{{ 'cart.remove' | t }}"
              data-line-remove
              data-line="{{ forloop.index }}"
            >
              {{ 'cart.remove' | t }}
            </button>
          </div>
        </div>
      </li>
    {%- endfor -%}
  </ul>
</valor-cart-items>

{% stylesheet %}
  .valor-cart-items__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .valor-cart-items__item {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.875rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }
  .valor-cart-items__item:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .valor-cart-items__image {
    display: block;
    width: 5rem;
    height: 5rem;
    background-color: color-mix(in srgb, var(--color-foreground) 5%, transparent);
    overflow: hidden;
  }
  .valor-cart-items__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .valor-cart-items__details {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .valor-cart-items__row {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    align-items: baseline;
  }
  .valor-cart-items__title {
    font-size: 0.9375rem;
    font-weight: var(--font-body--weight-bold);
    color: var(--color-foreground);
    text-decoration: none;
    line-height: 1.3;
    flex: 1 1 auto;
    min-width: 0;
  }
  .valor-cart-items__title:hover {
    text-decoration: underline;
  }
  .valor-cart-items__price-block {
    flex: 0 0 auto;
    text-align: right;
  }
  .valor-cart-items__price {
    display: block;
    font-size: 0.9375rem;
    font-weight: var(--font-body--weight-bold);
    white-space: nowrap;
  }
  .valor-cart-items__unit-price {
    margin: 0.125rem 0 0;
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-foreground) 70%, transparent);
    white-space: nowrap;
  }
  .valor-cart-items__variant {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 85%, transparent);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .valor-cart-items__variant span:not(:last-child)::after {
    content: ' / ';
    margin-left: 0.5rem;
  }
  .valor-cart-items__discounts {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.75rem;
    color: var(--valor-color-success);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .valor-cart-items__discount {
    display: flex;
    gap: 0.375rem;
    align-items: center;
  }
  .valor-cart-items__discount-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--valor-color-success);
    color: var(--color-background);
    font-size: 0.75rem;
    font-weight: var(--font-body--weight-bold);
    line-height: 1;
    flex: 0 0 auto;
  }
  .valor-cart-items__discount-title {
    min-width: 0;
  }
  .valor-cart-items__discount-amount {
    margin-left: auto;
    font-weight: var(--font-body--weight-bold);
  }
  .valor-cart-items__compare-price {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-foreground) 75%, transparent);
  }
  .valor-cart-items__quantity {
    margin-top: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .valor-cart-items__qty-control {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--valor-border-strong);
    border-radius: var(--style-border-radius-inputs, 4px);
    overflow: hidden;
  }
  .valor-cart-items__qty-btn {
    background: transparent;
    border: 0;
    color: var(--color-foreground);
    width: 2rem;
    height: 2rem;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .valor-cart-items__qty-btn:hover {
    background: color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }
  .valor-cart-items__qty-input {
    width: 2.25rem;
    border: 0;
    background: transparent;
    color: var(--color-foreground);
    text-align: center;
    font: inherit;
    font-size: 0.875rem;
    border-left: 1px solid var(--valor-border-strong);
    border-right: 1px solid var(--valor-border-strong);
    -moz-appearance: textfield;
  }
  .valor-cart-items__qty-input::-webkit-outer-spin-button,
  .valor-cart-items__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .valor-cart-items__qty-input:focus {
    outline: none;
    background: color-mix(in srgb, var(--color-foreground) 5%, transparent);
  }
  .valor-cart-items__remove {
    background: transparent;
    border: 0;
    padding: 0;
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    font: inherit;
    font-size: 0.8125rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .valor-cart-items__remove:hover {
    color: var(--color-foreground);
  }

  /* Loading state during AJAX update */
  .valor-cart-items[aria-busy='true'] {
    opacity: 0.55;
    pointer-events: none;
  }
{% endstylesheet %}
