{%- comment -%}
  Renders social icons.

  Accepts:
  - class: {String} extra class to append to the <ul> element (optional).

  Usage:
  {% render 'social-icons', class: 'my-class' %}
{%- endcomment -%}

<ul class="valor-social-icons{% if class %} {{ class }}{% endif %}" role="list">
  {%- if settings.social_instagram_url != blank -%}
    <li class="valor-social-icons__item">
      <a
        href="{{ settings.social_instagram_url }}"
        class="valor-social-icons__link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="valor-social-icons__icon" aria-hidden="true">
          {{- 'icon-instagram.svg' | inline_asset_content -}}
        </span>
        <span class="visually-hidden">Instagram</span>
      </a>
    </li>
  {%- endif -%}
  {%- if settings.social_facebook_url != blank -%}
